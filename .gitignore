# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# data dirs
/data/raw
/generated
# Campaign Planner runtime store (user-generated plan rows)
/data/campaign-planner.json
# Overview response cache (L2 disk cache — regenerated on demand)
/data/cache
# Daily metrics store (synced from Klaviyo on a schedule; regenerated by sync)
/data/metrics

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
